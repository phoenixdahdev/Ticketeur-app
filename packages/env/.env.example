# @ticketur/env is the source of truth for all env vars in the monorepo.
# Every var validated by src/{core,server,client}.ts is listed below. Copy to
# .env and fill in. Consumers (db, auth, jobs, web) import from here.

# ─── Database ───────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/ticketur"

# ─── Better Auth ────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# Comma-separated list of trusted origins (apps that share auth)
APP_URLS="http://localhost:3000"

# ─── Google OAuth (optional) ────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Trigger.dev ────────────────────────────────────────────────────────
TRIGGER_PROJECT_ID=""
TRIGGER_SECRET_KEY=""

# ─── Resend ─────────────────────────────────────────────────────────────
RESEND_API_KEY=""

# ─── Public (Next.js) ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
