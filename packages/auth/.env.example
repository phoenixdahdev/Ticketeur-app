# Required by src/server.ts (Better Auth config).
# DATABASE_URL is transitively required via the @ticketur/db import.

DATABASE_URL="postgresql://user:password@localhost:5432/ticketur"

# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# Comma-separated list of trusted origins
APP_URLS="http://localhost:3000"

# ─── Google OAuth (optional — only wired if both are set) ───────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
