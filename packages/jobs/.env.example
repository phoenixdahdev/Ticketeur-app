# Read by trigger.config.ts and src/tasks/*.
# DATABASE_URL is transitively required via the @ticketur/db import chain.

DATABASE_URL="postgresql://user:password@localhost:5432/ticketur"

# ─── Trigger.dev ────────────────────────────────────────────────────────
# Project ID from https://cloud.trigger.dev (required to run `trigger dev`)
TRIGGER_PROJECT_ID=""
# Only needed for `trigger deploy`
TRIGGER_SECRET_KEY=""

# ─── Resend (used inside each task via src/utils/resend.ts) ─────────────
RESEND_API_KEY=""
