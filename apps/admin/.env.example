# ─── Public (Next.js) ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3001"

# ─── Database (Postgres) ────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/ticketur"

# ─── Better Auth ────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3001"

# Comma-separated list of trusted origins (apps that share auth)
APP_URLS="http://localhost:3000,http://localhost:3001"

# ─── Google OAuth (optional) ────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Trigger.dev (outbound emails — password reset, 2FA, verification) ──
TRIGGER_PROJECT_ID=""
TRIGGER_SECRET_KEY=""

# ─── Resend (read by packages/jobs when running) ────────────────────────
RESEND_API_KEY=""

# ─── Vercel Blob (uploads) ──────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=""
