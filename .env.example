# ─── Database (Postgres) ────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/ticketur"

# ─── Better Auth ────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# Comma-separated list of trusted origins (apps that share auth)
APP_URLS="http://localhost:3000"

# ─── Google OAuth (optional) ────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Trigger.dev (background jobs) ──────────────────────────────────────
TRIGGER_PROJECT_ID=""
TRIGGER_SECRET_KEY=""

# ─── Resend (transactional email) ───────────────────────────────────────
RESEND_API_KEY=""

# ─── Vercel Blob (uploads — event banner, vendor logo/banner/showcase) ──
BLOB_READ_WRITE_TOKEN=""

# ─── Flutterwave (Standard checkout for ticket purchases) ───────────────
# Test keys start with FLWPUBK_TEST- / FLWSECK_TEST-. The webhook secret is
# whatever string you set under "Secret hash" in the Flutterwave dashboard;
# we compare it against the `verif-hash` header on inbound webhooks.
FLW_PUBLIC_KEY=""
FLW_SECRET_KEY=""
FLW_SECRET_HASH=""

# ─── Public (Next.js) ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
